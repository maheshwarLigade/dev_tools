{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.devtools.app",
    "productName": "DevTools",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/crypto-js": "^4.2.2",
    "@types/prismjs": "^1.26.6",
    "@vitejs/plugin-react": "^5.0.4",
    "ajv": "^8.20.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.3",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "react-syntax-highlighter": "^16.1.1",
    "sql-formatter": "^15.7.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
